rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: resumes
    // Document ID: {userId}
    // Fields:
    //   - personalInfo: map (required)
    //   - summary: string
    //   - experience: list
    //   - education: list
    //   - skills: list
    //   - projects: list
    //   - certifications: list
    //   - languages: list
    //   - updatedAt: timestamp (required)
    //   - userId: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "james@buildwaveai.com" || 
         request.auth.token.email == "reality150@gmail.com");
    }

    function isValidResume(data) {
      return data.keys().hasAll(['personalInfo', 'userId', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.personalInfo is map &&
             data.updatedAt is timestamp &&
             (!('summary' in data) || data.summary is string) &&
             (!('experience' in data) || data.experience is list) &&
             (!('education' in data) || data.education is list) &&
             (!('skills' in data) || data.skills is list) &&
             (!('projects' in data) || data.projects is list) &&
             (!('certifications' in data) || data.certifications is list) &&
             (!('languages' in data) || data.languages is list) &&
             (!('isPublic' in data) || data.isPublic is bool);
    }

    function isValidProfile(data) {
      return (!('fullName' in data) || data.fullName is string) &&
             (!('email' in data) || data.email is string) &&
             (!('phone' in data) || data.phone is string) &&
             (!('socials' in data) || data.socials is map) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    match /resumes/{userId} {
      allow read: if isOwner(userId) || isAdmin() || (resource != null && resource.data.isPublic == true);
      allow create: if isOwner(userId) && isValidResume(request.resource.data);
      allow update: if isOwner(userId) && isValidResume(request.resource.data);
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidProfile(request.resource.data);
    }

    // Allow admins to list all resumes
    match /resumes {
      allow list: if isAdmin();
    }
  }
}
